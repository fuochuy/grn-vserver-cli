#!/usr/bin/env python3
"""Extract release notes for a specific version from CHANGELOG.md.

Usage: scripts/extract-release-notes <version>
  version — without the leading 'v', e.g. 1.3.2

Prints the markdown block for that version to stdout.
Exits with code 1 if the version is not found.
"""

import re
import sys
import os

if len(sys.argv) != 2:
    print(f"Usage: {sys.argv[0]} <version>", file=sys.stderr)
    sys.exit(1)

version = sys.argv[1].lstrip("v")
changelog = os.path.join(os.path.dirname(os.path.dirname(os.path.abspath(__file__))), "CHANGELOG.md")

with open(changelog) as f:
    content = f.read()

# Match the section for the requested version up to the next ## heading
pattern = rf"(## \[{re.escape(version)}\].*?)(?=\n## |\Z)"
match = re.search(pattern, content, re.DOTALL)

if not match:
    print(f"ERROR: version {version} not found in CHANGELOG.md", file=sys.stderr)
    sys.exit(1)

notes = match.group(1).strip()
# Remove the version heading line — GitHub release title already shows the tag
notes = re.sub(r"^## \[.*?\] - \d{4}-\d{2}-\d{2}\n+", "", notes)
print(notes.strip())
